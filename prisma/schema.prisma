generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Shop {
  id          String   @id @default(cuid())
  shopDomain  String   @unique
  accessToken String
  plan        String   @default("free")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Widget design customization — lets merchants match their store's
  // branding instead of a fixed look, and choose how reviews are laid out.
  displayStyle    String @default("list")    // "list" | "grid" | "carousel"
  gridColumns     Int    @default(3)          // only used when displayStyle = "grid"
  carouselVisible Int    @default(1)          // cards visible at once, carousel only
  arrowColor      String @default("#111111")  // carousel prev/next arrow color
  primaryColor    String @default("#111111")  // buttons, "write a review" CTA
  starColor       String @default("#f5b400")
  backgroundColor String @default("#ffffff")
  textColor       String @default("#333333")
  borderRadius    Int    @default(8)          // px, applied to cards/buttons
  fontFamily      String @default("inherit")

  // Controls where/how big the "write a review" form appears — merchant
  // configurable instead of hardcoded, since it needs to fit their theme.
  formAlign    String @default("left")  // "left" | "center" | "right"
  formMaxWidth Int    @default(420)      // px

  // Whether to show the auto-suggestion picker (with refresh) when
  // writing a review — configurable separately for the storefront widget
  // vs. the QR-scan flow, since merchants may want one but not the other.
  showSuggestionsOnWebsite Boolean @default(true)
  showSuggestionsOnQr      Boolean @default(true)

  // Optional reward for leaving a review — merchant toggles this on and
  // picks a discount type/value. When enabled, every review submission
  // generates a one-time Shopify discount code shown right on the
  // "thanks for your review" screen (no email needed).
  rewardEnabled Boolean @default(false)
  rewardType    String  @default("percentage") // "percentage" | "fixed_amount"
  rewardValue   Float   @default(10)            // e.g. 10 = 10% or $10 depending on type

  // Automated "leave a review" reminder emails, sent a configurable delay
  // after purchase if the customer hasn't already reviewed that product.
  reminderEnabled   Boolean @default(false)
  reminderDelayDays Int     @default(7) // days after order before sending
  fromEmail         String? // merchant's own address, used as Reply-To on reminder emails (actual "From" always stays on the app's own verified sending domain)
  emailSubject      String  @default("How did you like your purchase?")
  emailBodyTemplate String  @default("Hi {{first_name}},\n\nThank you for your recent order. We'd love to hear your feedback!\n\nLeave a review here: {{review_link}}\n\nThanks,\n{{shop_name}}") @db.Text

  reviews          Review[]
  reminderRequests PendingReviewRequest[]
  reminderUnsubscribes ReminderUnsubscribe[]
}

// One row per (order, product) pair that's a candidate for a review
// reminder email. Created when an order webhook fires; the reminder cron
// checks these against elapsed time and whether a review already exists
// for that email+product before sending.
model PendingReviewRequest {
  id              String    @id @default(cuid())
  shopId          String
  shop            Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  orderId         String
  productId       String
  productTitle    String
  productImageUrl String?
  customerEmail   String
  customerName    String?

  purchasedAt    DateTime
  reminderSentAt DateTime?
  reviewed       Boolean   @default(false) // set true once this email reviews this product

  @@unique([shopId, orderId, productId])
  @@index([shopId, reminderSentAt, reviewed])
}

// One row per (shop, email) that has clicked "unsubscribe" on a reminder
// email — checked before sending any future reminder to that address.
model ReminderUnsubscribe {
  id            String   @id @default(cuid())
  shopId        String
  shop          Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerEmail String
  createdAt     DateTime @default(now())

  @@unique([shopId, customerEmail])
}

// A single customer review, either submitted through our own storefront
// widget or imported later from another source. Merchant approves before
// it shows publicly on the product page or becomes eligible for a UGC card.
model Review {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  productId    String // Shopify product GID
  productTitle String
  productImageUrl String? // used as the background/photo in generated UGC cards

  rating      Int      // 1-5
  body        String   @db.Text
  customerName String
  customerEmail String? // used to prevent duplicate reminder emails once someone reviews
  photoUrl    String?  @db.Text // optional customer-submitted photo (stored as base64 data URI for simplicity)

  approved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  ugcCards UgcCard[]

  @@index([shopId, productId])
  @@index([shopId, approved])
}

// A generated social-media graphic for a specific review + template combo.
// Cached so re-downloading/re-sharing doesn't regenerate the image.
model UgcCard {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  template  String   // e.g. "quote-minimal", "story-bold", "square-photo"
  format    String   // "story" (1080x1920) | "post" (1080x1080)
  imageUrl  String   // stored asset URL (Vercel Blob or similar)

  createdAt DateTime @default(now())

  @@index([reviewId])
}
