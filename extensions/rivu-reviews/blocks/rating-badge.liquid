{% comment %}
  Rivu Rating Badge — shows average stars + review count.
  Clicking it scrolls to the full review section.
  Add near your product title: Customize → Product page → Add block → Apps → Rivu Rating Badge
{% endcomment %}

<div
  id="rivu-rating-badge-{{ block.id }}"
  class="rivu-rating-badge"
  data-shop="{{ shop.permanent_domain }}"
  data-product-id="{{ product.id }}"
  data-api-base="https://rivu-one.vercel.app"
  {{ block.shopify_attributes }}
></div>
<script src="{{ 'rivu-rating-badge.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Rivu Rating Badge",
  "target": "section",
  "settings": []
}
{% endschema %}
