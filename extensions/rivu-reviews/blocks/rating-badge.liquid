{% comment %}
  Rivu Rating Badge — shows average stars near product title.
  Clicking scrolls to the full review section below.
  Add via: Customize → Product page → Add block → Apps → Rivu Rating Badge
  
  NOTE: The App Embed also auto-injects badges on collection cards.
  On the product page, use ONLY this block (not both).
{% endcomment %}

<div
  class="rivu-rating-badge"
  data-shop="{{ shop.permanent_domain }}"
  data-product-id="{{ product.id }}"
  data-api-base="https://rivu-one.vercel.app"
  {{ block.shopify_attributes }}
></div>
<script src="{{ 'rivu-rating-badge.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Rivu Rating Badge",
  "target": "section",
  "settings": []
}
{% endschema %}
