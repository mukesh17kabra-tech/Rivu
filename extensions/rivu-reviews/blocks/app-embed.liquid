{% comment %}
  Rivu App Embed — enable this in Theme Editor → App Embeds.
  Loads the star badge script globally and auto-injects ratings on product cards.
{% endcomment %}

<script
  src="{{ 'rivu-rating-badge.js' | asset_url }}"
  data-shop="{{ shop.permanent_domain }}"
  data-api-base="https://rivu-one.vercel.app"
  data-auto-inject="true"
  data-badge-star-size="{{ block.settings.badge_star_size }}"
  {{ block.shopify_attributes }}
></script>

{% schema %}
{
  "name": "Rivu App Embed",
  "target": "body",
  "settings": [
    {
      "type": "range",
      "id": "badge_star_size",
      "label": "Star size on product cards",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 14,
      "unit": "px"
    }
  ]
}
{% endschema %}
