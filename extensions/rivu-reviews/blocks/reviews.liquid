{% comment %}
  Rivu Reviews Block — add to your product page template via the theme
  editor (Customize → Product page → Add block → Apps → Rivu Reviews).
  
  IMPORTANT: Only add this block ONCE. Adding it twice will show the
  widget twice on the same page.
{% endcomment %}

<div
  id="rivu-review-section"
  class="rivu-review-widget"
  data-shop="{{ shop.permanent_domain }}"
  data-product-id="{{ product.id }}"
  data-product-title="{{ product.title | escape }}"
  data-product-image="{{ product.featured_image | image_url: width: 800 }}"
  data-api-base="{{ block.settings.api_base }}"
  {{ block.shopify_attributes }}
></div>
<script src="{{ 'rivu-widget.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Rivu Reviews",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "api_base",
      "label": "App URL",
      "default": "https://rivu-one.vercel.app",
      "info": "Do not change this unless instructed by the developer."
    }
  ]
}
{% endschema %}
