{% comment %}
  Rivu Reviews Block
  Add once to your product page via: Customize → Product page → Add block → Apps → Rivu Reviews
  Only add this block ONCE — adding it twice will show reviews twice.
{% endcomment %}

<div
  id="rivu-review-section"
  class="rivu-review-widget"
  data-shop="{{ shop.permanent_domain }}"
  data-product-id="{{ product.id }}"
  data-product-title="{{ product.title | escape }}"
  data-product-image="{{ product.featured_image | image_url: width: 800 }}"
  data-api-base="https://rivu-one.vercel.app"
  {{ block.shopify_attributes }}
></div>
<script src="{{ 'rivu-widget.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Rivu Reviews",
  "target": "section",
  "settings": []
}
{% endschema %}
